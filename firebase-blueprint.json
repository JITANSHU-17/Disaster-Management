{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile data following the application User interface.",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Firebase UID" },
        "name": { "type": "string", "description": "Full name" },
        "email": { "type": "string", "format": "email" },
        "role": { "type": "string", "enum": ["ADMIN", "TEACHER", "STUDENT"] },
        "institution": { "type": "string" }
      },
      "required": ["id", "name", "email", "role", "institution"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profile documents."
    }
  }
}
